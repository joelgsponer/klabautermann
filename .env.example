# Klabautermann Environment Configuration
# =========================================
# Copy to .env and fill in values:
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control!

# === REQUIRED FOR SPRINT 1 ===

# Anthropic API (Claude) - Primary LLM
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI API (Embeddings) - For vector search
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Neo4j Database
# For Docker: bolt://neo4j:7687
# For local:  bolt://localhost:7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=klabautermann

# === REQUIRED FOR SPRINT 2 (MCP Integration) ===

# Google OAuth (run: python scripts/bootstrap_auth.py)
# Set up at: https://console.cloud.google.com/
# 1. Create/select project
# 2. Enable Gmail API and Calendar API
# 3. Create OAuth2 credentials (Desktop application)
# 4. Download credentials.json to project root
# 5. Run: python scripts/bootstrap_auth.py
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# === REQUIRED FOR SPRINT 4 (Telegram Channel) ===

# Telegram Bot
# Create via @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=

# === OPTIONAL CONFIGURATION ===

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json (for production) or text (for development)
LOG_FORMAT=text

# Model selection overrides (defaults shown)
# ORCHESTRATOR_MODEL=claude-sonnet-4-20250514
# HAIKU_MODEL=claude-3-5-haiku-20241022

# Embedding model
# EMBEDDING_MODEL=text-embedding-3-small

# Context window size (number of messages to include)
# CONTEXT_WINDOW_SIZE=20

# === DEVELOPMENT ONLY ===

# Enable debug mode (verbose logging, no background tasks)
# DEBUG=false

# Disable entity extraction (for testing conversation flow)
# DISABLE_INGESTION=false
